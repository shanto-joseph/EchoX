<Window x:Class="EchoX.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="About EchoX"
        Width="360"
        Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#111416"
        WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="0"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Background="#111416"
            BorderBrush="#2E3238"
            BorderThickness="1"
            CornerRadius="16"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16,14"
                    BorderBrush="#2E3238"
                    BorderThickness="0,0,0,1"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="About EchoX"
                                   Foreground="#EDEDF0"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AppVersion, StringFormat=Version {0}}"
                                   Foreground="#8A9199"
                                   FontSize="11"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Click="CloseBtn_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent" CornerRadius="8">
                                    <TextBlock Text="&#xE711;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               Foreground="#8A9199"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#24272C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="16,16"
                        BorderBrush="#2E3238"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Width="68"
                              Height="68"
                              VerticalAlignment="Center">
                            <Image Source="Assets/LOGO/EchoX.ico"
                                   Margin="4"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="22" FontWeight="Bold">
                                <Run Foreground="#EDEDF0">Echo</Run><Run Foreground="#53C028">X</Run>
                            </TextBlock>
                            <TextBlock Text="Audio control for Windows"
                                       Foreground="#8A9199"
                                       FontSize="11"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="by SHANTO JOSEPH"
                                       Foreground="#EDEDF0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,0"/>
                            <TextBlock FontSize="11"
                                       Margin="0,4,0,0">
                                <Hyperlink NavigateUri="https://github.com/shanto-joseph/EchoX"
                                           RequestNavigate="CreatorLink_RequestNavigate"
                                           Foreground="#53C028"
                                           TextDecorations="{x:Null}">
                                    View project on GitHub
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock FontSize="11"
                                       Margin="0,4,0,0">
                                <Hyperlink NavigateUri="https://echox.notrazer.xyz/"
                                           RequestNavigate="CreatorLink_RequestNavigate"
                                           Foreground="#53C028"
                                           TextDecorations="{x:Null}">
                                    Visit EchoX website
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE790;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#53C028"
                                       FontSize="14"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Support EchoX"
                                           Foreground="#EDEDF0"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="If EchoX helps your setup, you can support future updates here."
                                           Foreground="#8A9199"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Button Grid.Row="1"
                                Height="30"
                                Margin="24,14,0,0"
                                Padding="14,0"
                                HorizontalAlignment="Left"
                                Click="BuyMeCoffeeBtn_Click"
                                Cursor="Hand"
                                Background="#53C028"
                                BorderBrush="#53C028"
                                Foreground="#111416"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Content="Buy me a coffee"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
