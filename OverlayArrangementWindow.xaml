<Window x:Class="EchoX.OverlayArrangementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arrange Overlays"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#C60B0E0F"
        WindowStartupLocation="Manual">
    <Grid MouseMove="Window_MouseMove" MouseLeftButtonUp="Window_MouseLeftButtonUp">
        <Grid.Resources>
            <Style x:Key="OverlayActionButton" TargetType="Button">
                <Setter Property="Foreground" Value="#EDEDF0"/>
                <Setter Property="Background" Value="#24272C"/>
                <Setter Property="BorderBrush" Value="#343841"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="18,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#53C028"/>
                                    <Setter TargetName="Root" Property="Background" Value="#2A2E35"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PrimaryOverlayActionButton" TargetType="Button" BasedOn="{StaticResource OverlayActionButton}">
                <Setter Property="Foreground" Value="#041004"/>
                <Setter Property="Background" Value="#53C028"/>
                <Setter Property="BorderBrush" Value="#53C028"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    Padding="18,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.78"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Canvas x:Name="DesignCanvas">
            <Border x:Name="TopPanel"
                    Canvas.Left="24"
                    Canvas.Top="24"
                    Width="420"
                    Background="#EA191B1F"
                    BorderBrush="#2E3238"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18,16">
                <StackPanel>
                    <TextBlock Text="Arrange Overlays"
                               Foreground="#EDEDF0"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Drag each preview where you want it to appear on this monitor."
                               Foreground="#8A9199"
                               FontSize="12"
                               Margin="0,6,0,0"/>
                    <TextBlock x:Name="MonitorText"
                               Foreground="#53C028"
                               FontSize="11"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border x:Name="ActionBar"
                    Background="#EA191B1F"
                    BorderBrush="#2E3238"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12">
                <StackPanel Orientation="Horizontal">
                <Button Content="Reset"
                        Style="{StaticResource OverlayActionButton}"
                        Width="92"
                        Height="38"
                        Margin="0,0,12,0"
                        Click="ResetBtn_Click"/>
                <Button Content="Cancel"
                        Style="{StaticResource OverlayActionButton}"
                        Width="96"
                        Height="38"
                        Margin="0,0,12,0"
                        Click="CancelBtn_Click"/>
                <Button Content="Apply"
                        Style="{StaticResource PrimaryOverlayActionButton}"
                        Width="104"
                        Height="38"
                        Click="ApplyBtn_Click"/>
                </StackPanel>
            </Border>

            <Border x:Name="NotificationPreview"
                    Width="180"
                    Background="#F0191B1F"
                    BorderBrush="#2E3238"
                    BorderThickness="1"
                    CornerRadius="10"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="Preview_MouseLeftButtonDown"
                    MouseLeftButtonUp="Preview_MouseLeftButtonUp">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#000000" Opacity="0.45"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" Margin="12,10,14,10">
                    <Viewbox Width="18" Height="18" Margin="0,1,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#53C028" Stretch="Uniform"
                                  Data="M3.559 4.544c.355-.35.834-.544 1.33-.544H19.11c.496 0 .975.194 1.33.544.356.35.559.829.559 1.331v9.25c0 .502-.203.981-.559 1.331-.355.35-.834.544-1.33.544H15.5l-2.7 3.6a1 1 0 0 1-1.6 0L8.5 17H4.889c-.496 0-.975-.194-1.33-.544A1.868 1.868 0 0 1 3 15.125v-9.25c0-.502.203-.981.559-1.331ZM7.556 7.5a1 1 0 1 0 0 2h8a1 1 0 0 0 0-2h-8Zm0 3.5a1 1 0 1 0 0 2H12a1 1 0 1 0 0-2H7.556Z"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="Notification Popup"
                                   Foreground="#EDEDF0"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Drag me like Discord"
                                   Foreground="#8A9199"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="MutePreview"
                    Width="36"
                    Height="36"
                    Background="#E6191B1F"
                    BorderBrush="#2E3238"
                    BorderThickness="1"
                    CornerRadius="8"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="Preview_MouseLeftButtonDown"
                    MouseLeftButtonUp="Preview_MouseLeftButtonUp">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#000000" Opacity="0.45"/>
                </Border.Effect>
                <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="16" Height="16">
                        <Path Fill="#EF4444" Stretch="Uniform"
                              Data="M10.949933333333334 11.892666666666665c-0.688 0.3892 -1.4605333333333332 0.6464666666666666 -2.2831333333333332 0.7374V15.333333333333332h-1.3333333333333333v-2.7032666666666665C4.55236 12.322599999999998 2.3441533333333333 10.1144 2.0367266666666666 7.333333333333333h1.3439733333333335c0.32348 2.2615333333333334 2.26842 4 4.619433333333333 4 0.7000666666666666 0 1.3641333333333332 -0.15413333333333332 1.9601333333333333 -0.43039999999999995l-1.0334666666666665 -1.0334666666666665c-0.2942 0.08499999999999999 -0.6051333333333333 0.13053333333333333 -0.9266666666666665 0.13053333333333333 -1.84098 0 -3.33336 -1.4924 -3.33336 -3.333333333333333V5.609473333333334l-3.7377399999999996 -3.7377333333333334L1.8718466666666667 0.9289333333333333l13.199353333333331 13.199333333333332 -0.9428666666666665 0.9427999999999999 -3.1784 -3.1784Zm1.9665333333333335 -1.7857333333333332 -0.9615999999999999 -0.9616666666666666c0.3389333333333333 -0.5396666666666666 0.5704666666666667 -1.1536666666666666 0.6646666666666666 -1.8119333333333334h1.3439333333333332c-0.1132 1.0244 -0.48433333333333334 1.971 -1.047 2.7736Zm-1.9392666666666667 -1.9393333333333331L5.123833333333333 2.31426C5.702846666666667 1.3284533333333333 6.7742 0.6666666666666666 8.000133333333332 0.6666666666666666c1.8409333333333333 0 3.333333333333333 1.4923866666666665 3.333333333333333 3.333333333333333v2.6666666666666665c0 0.5399333333333333 -0.1284 1.0498666666666665 -0.3562666666666666 1.5009333333333332Z"/>
                    </Canvas>
                </Viewbox>
            </Border>

            <Border x:Name="FooterHint"
                    Canvas.Left="24"
                    Background="#CC111416"
                    BorderBrush="#2E3238"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14,10">
                <TextBlock Text="Tip: positions are saved for this monitor and reused by both overlays."
                           Foreground="#8A9199"
                           FontSize="11"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
