<Window x:Class="EchoX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:EchoX.Converters"
        Title="EchoX" Height="680" Width="1000"
        Icon="Assets/LOGO/EchoX_exe.ico"
        Background="#0F0F11" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="5"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <converters:ObjectEqualityConverter x:Key="ObjectEqualityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:GreaterThanConverter x:Key="GreaterThanConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgBase"      Color="#0F0F11"/>
        <SolidColorBrush x:Key="BgSurface"   Color="#17171A"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1E1E22"/>
        <SolidColorBrush x:Key="BgRaised"    Color="#26262B"/>
        <SolidColorBrush x:Key="Border"      Color="#2E2E34"/>
        <SolidColorBrush x:Key="Accent"      Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentLow"   Color="#16532A"/>
        <SolidColorBrush x:Key="AccentGlow"  Color="#22C55E22"/>
        <SolidColorBrush x:Key="AccentDim"   Color="#1B9A4A"/>
        <SolidColorBrush x:Key="TextHi"      Color="#EDEDF0"/>
        <SolidColorBrush x:Key="TextMid"     Color="#9898A0"/>
        <SolidColorBrush x:Key="TextLow"     Color="#55555E"/>
        <SolidColorBrush x:Key="Blue"        Color="#3B82F6"/>
        <SolidColorBrush x:Key="BlueLow"     Color="#1E3A5F"/>
        <SolidColorBrush x:Key="Red"         Color="#F87171"/>
        <SolidColorBrush x:Key="Amber"       Color="#FBBF24"/>

        <!-- Global Styles -->
        <Style TargetType="Control">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
        </Style>

        <!-- NAV BUTTON -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"                 Value="{StaticResource TextMid}"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Height"                     Value="42"/>
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="0,6,6,0" Margin="0,1,8,1"/>
                            <Border x:Name="Pill" Background="Transparent" Width="3"
                                    HorizontalAlignment="Left" CornerRadius="0,2,2,0"/>
                            <ContentPresenter Margin="20,0,12,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"   Property="Background" Value="#1E1E22"/>
                                <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bg" Background="#16532A1A" CornerRadius="0,6,6,0" Margin="0,1,8,1"/>
                            <Border Background="{StaticResource Accent}" Width="3"
                                    HorizontalAlignment="Left" CornerRadius="0,2,2,0"/>
                            <ContentPresenter Margin="20,0,12,0" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ICON BUTTON (circle) -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BgRaised}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMid}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#3B82F620"/>
                                <Setter Property="Foreground" Value="{StaticResource Blue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"      Value="#0A1F12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R" Background="{TemplateBinding Background}" CornerRadius="7" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="R" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMid}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="R" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#1E1E22"/>
                                <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Foreground"  Value="{StaticResource Red}"/>
            <Setter Property="BorderBrush" Value="#F8717130"/>
        </Style>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgRaised}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextHi}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Accent}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentLow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="R" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="R" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BgRaised}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextHi}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="7"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  TextElement.Foreground="{StaticResource TextHi}"
                                                  Margin="10,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource TextMid}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ToggleButton Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"
                                   Focusable="False" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="{StaticResource BgCard}"
                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                        CornerRadius="7" Margin="0,4,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="10,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="R" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="R" Property="Background" Value="{StaticResource BgRaised}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="R" Property="Background" Value="{StaticResource AccentLow}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LISTBOX -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- LISTBOXITEM -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="Margin"     Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="R" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#26262B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#16532A30"/>
                                <Setter TargetName="R" Property="BorderBrush" Value="#22C55E30"/>
                                <Setter TargetName="R" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SLIDER -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Minimum"          Value="0"/>
            <Setter Property="Maximum"          Value="100"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <EventSetter Event="PreviewMouseWheel" Handler="VolumeSlider_PreviewMouseWheel"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{StaticResource Accent}" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{StaticResource BgRaised}" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="14" Background="{StaticResource Accent}"
                                                        CornerRadius="7" BorderBrush="#0F0F11" BorderThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CHECKBOX -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- SCROLLBAR -->
        <Style x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="MinWidth"   Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0"
                                                  Focusable="False" Height="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A42" CornerRadius="3" Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0"
                                                  Focusable="False" Height="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SCROLLVIEWER -->
        <Style x:Key="{x:Type ScrollViewer}" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CARD -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <!-- LABEL -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLow}"/>
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBase}" CornerRadius="0"
            BorderBrush="{StaticResource Border}" BorderThickness="0"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
            TextElement.Foreground="{StaticResource TextHi}">
        <Grid>
            <!-- ══════════════════════════════════ MAIN LAYOUT -->
            <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="196"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════ SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo + window controls -->
                <Grid DockPanel.Dock="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="16,16,16,14">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="Transparent" CornerRadius="8" 
                                    Width="32" Height="32" Margin="0,0,10,0">
                                <Image Source="Assets/LOGO/EchoX.ico" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="EchoX" Foreground="{StaticResource TextHi}"
                                           FontSize="15" FontWeight="Bold"/>
                                <TextBlock Text="Audio Manager" Foreground="{StaticResource TextLow}"
                                           FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Separator DockPanel.Dock="Top" Background="{StaticResource Border}" Height="1" Margin="0,0,0,8"/>

                <!-- Version pinned to bottom — must be declared before the fill item -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,0,18" VerticalAlignment="Bottom" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">
                        <Hyperlink NavigateUri="https://github.com/shanto-joseph/EchoX" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource TextLow}" TextDecorations="{x:Null}" ToolTip="View on GitHub">
                            <InlineUIContainer>
                                <Viewbox Height="16" Width="16">
                                    <Path Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" 
                                          Fill="{StaticResource TextLow}"/>
                                </Viewbox>
                            </InlineUIContainer>
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="v1.0.0" Foreground="{StaticResource TextLow}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel DockPanel.Dock="Top" Margin="0,4,0,0">
                    <Button x:Name="BtnNav0" Tag="Communication" Click="SidebarButton_Click"
                            Style="{StaticResource NavBtnActive}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="13" Height="13" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Path Data="M14 12v2h-1.3333333333333333v-2h-1.3333333333333333v-2h4v2h-1.3333333333333333ZM3.333333333333333 12v2H2v-2H0.6666666666666666v-2h4v2H3.333333333333333Zm4 -8V2h1.3333333333333333v2h1.3333333333333333v2H6V4h1.3333333333333333Zm0 3.333333333333333h1.3333333333333333v6.666666666666666h-1.3333333333333333V7.333333333333333Zm-5.333333333333333 1.3333333333333333V2h1.3333333333333333v6.666666666666666H2Zm10.666666666666666 0V2h1.3333333333333333v6.666666666666666h-1.3333333333333333Z" 
                                      Fill="{StaticResource Accent}"/>
                            </Viewbox>
                            <TextBlock Text="Devices" FontSize="13" Foreground="{StaticResource Accent}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNav1" Tag="Profiles" Click="SidebarButton_Click"
                            Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,10,0"
                                       Foreground="{StaticResource TextMid}"/>
                            <TextBlock Text="Profiles" FontSize="13" Foreground="{StaticResource TextMid}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNav2" Tag="Shortcuts" Click="SidebarButton_Click"
                            Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE92E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,10,0"
                                       Foreground="{StaticResource TextMid}"/>
                            <TextBlock Text="Shortcuts" FontSize="13" Foreground="{StaticResource TextMid}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNav3" Tag="Settings" Click="SidebarButton_Click"
                            Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,10,0"
                                       Foreground="{StaticResource TextMid}"/>
                            <TextBlock Text="Settings" FontSize="13" Foreground="{StaticResource TextMid}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnNav4" Tag="About" Click="SidebarButton_Click"
                            Style="{StaticResource NavBtn}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,10,0"
                                       Foreground="{StaticResource TextMid}"/>
                            <TextBlock Text="About" FontSize="13" Foreground="{StaticResource TextMid}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════ CONTENT -->
        <TabControl x:Name="MainTabControl" Grid.Column="1"
                    Background="{StaticResource BgBase}" BorderThickness="0" SelectedIndex="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ──────────────────────── DEVICES TAB -->
            <TabItem Header="Communication">
                <Grid Margin="28,24,28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Devices" Foreground="{StaticResource TextHi}"
                                           FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <!-- Profile Button Link -->
                                    <Button Cursor="Hand" Click="ProfileHeading_Click" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <StackPanel x:Name="Container" Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DevicesViewModel.ActiveProfileName}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DevicesViewModel.ActiveProfileName}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="|" Foreground="{StaticResource TextLow}"
                                                               FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="Ico" Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                                               Foreground="{StaticResource Accent}"
                                                               FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="Txt" Text="{Binding DevicesViewModel.ActiveProfileName}"
                                                               Foreground="{StaticResource Accent}"
                                                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource TextHi}"/>
                                                        <Setter TargetName="Txt" Property="Foreground" Value="{StaticResource TextHi}"/>
                                                        <Setter Property="ToolTip" Value="Go to Profiles"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                            </StackPanel>
                            <TextBlock Text="Select a device to set it as the Windows default"
                                       Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Device lists -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Input -->
                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Padding="14,12,14,12"
                                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextMid}"
                                                       FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Microphones" Foreground="{StaticResource TextHi}"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Test Toggle Button -->
                                        <ToggleButton HorizontalAlignment="Right" VerticalAlignment="Center"
                                                      IsChecked="{Binding DevicesViewModel.IsMicTestExpanded}"
                                                      Cursor="Hand" ToolTip="Test Mic">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="8" Padding="12,8">
                                                        <Path x:Name="TxtIcon" Data="M3.333333333333333 4.666666666666666h1.3333333333333333v6.666666666666666H3.333333333333333V4.666666666666666Zm-2.6666666666666665 2h1.3333333333333333v2.6666666666666665H0.6666666666666666v-2.6666666666666665Zm5.333333333333333 -5.333333333333333h1.3333333333333333v12H6V1.3333333333333333Zm2.6666666666666665 1.3333333333333333h1.3333333333333333v12h-1.3333333333333333V2.6666666666666665Zm2.6666666666666665 2h1.3333333333333333v6.666666666666666h-1.3333333333333333V4.666666666666666Zm2.6666666666666665 2h1.3333333333333333v2.6666666666666665h-1.3333333333333333v-2.6666666666666665Z"
                                                              Fill="{StaticResource TextMid}" Height="20" Width="20" Stretch="Uniform"
                                                              VerticalAlignment="Center">
                                                            <Path.RenderTransformOrigin>
                                                                <Point X="0.5" Y="0.5"/>
                                                            </Path.RenderTransformOrigin>
                                                            <Path.RenderTransform>
                                                                <ScaleTransform x:Name="HeaderScale" ScaleX="1" ScaleY="1"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#1E1E22"/>
                                                            <Setter TargetName="TxtIcon" Property="Fill" Value="{StaticResource TextHi}"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard x:Name="HoverPulse">
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="HeaderScale"
                                                                                         Storyboard.TargetProperty="ScaleX"
                                                                                         To="1.15" Duration="0:0:0.6" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                        <DoubleAnimation Storyboard.TargetName="HeaderScale"
                                                                                         Storyboard.TargetProperty="ScaleY"
                                                                                         To="1.15" Duration="0:0:0.6" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="HoverPulse"/>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="TxtIcon" Property="Fill" Value="{StaticResource Accent}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding DevicesViewModel.IsMicTesting}" Value="True">
                                                            <Setter TargetName="TxtIcon" Property="Fill" Value="#DA373C"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                    </Grid>
                                </Border>
                                
                                <!-- Mic Test Section (Dropdown Style) -->
                                <Border DockPanel.Dock="Top" Background="#0A0F0F11" Padding="16,16,16,20"
                                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                                        Visibility="{Binding DevicesViewModel.IsMicTestExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Test Button -->
                                            <Button Grid.Column="0" Command="{Binding DevicesViewModel.ToggleMicTestCommand}"
                                                    Width="76" Height="34" Cursor="Hand" Margin="0,0,16,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="BtnBg" Background="#2B2D31" CornerRadius="8">
                                                                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                             <Path x:Name="BtnIcon" Data="M3.333333333333333 4.666666666666666h1.3333333333333333v6.666666666666666H3.333333333333333V4.666666666666666Zm-2.6666666666666665 2h1.3333333333333333v2.6666666666666665H0.6666666666666666v-2.6666666666666665Zm5.333333333333333 -5.333333333333333h1.3333333333333333v12H6V1.3333333333333333Zm2.6666666666666665 1.3333333333333333h1.3333333333333333v12h-1.3333333333333333V2.6666666666666665Zm2.6666666666666665 2h1.3333333333333333v6.666666666666666h-1.3333333333333333V4.666666666666666Zm2.6666666666666665 2h1.3333333333333333v2.6666666666666665h-1.3333333333333333v-2.6666666666666665Z" 
                                                                                   Fill="White" Height="14" Width="14" Stretch="Uniform"
                                                                                   Margin="0,0,6,0">
                                                                                 <Path.RenderTransformOrigin>
                                                                                     <Point X="0.5" Y="0.5"/>
                                                                                 </Path.RenderTransformOrigin>
                                                                                 <Path.RenderTransform>
                                                                                     <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                                                                 </Path.RenderTransform>
                                                                             </Path>
                                                                             <TextBlock x:Name="BtnTxt" Text="Test" Foreground="White" 
                                                                                        FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                         </StackPanel>
                                                                     </Border>
                                                                     <ControlTemplate.Triggers>
                                                                         <Trigger Property="IsMouseOver" Value="True">
                                                                             <Setter TargetName="BtnBg" Property="Background" Value="#35373C"/>
                                                                         </Trigger>
                                                                         <DataTrigger Binding="{Binding DevicesViewModel.IsMicTesting}" Value="True">
                                                                             <Setter TargetName="BtnIcon" Property="Fill" Value="#DA373C"/>
                                                                             <Setter TargetName="BtnTxt" Property="Foreground" Value="#DA373C"/>
                                                                             <Setter TargetName="BtnTxt" Property="Text" Value="Stop"/>
                                                                             <DataTrigger.EnterActions>
                                                                                 <BeginStoryboard x:Name="PulseAnimation">
                                                                                     <Storyboard>
                                                                                         <DoubleAnimation Storyboard.TargetName="IconScale" 
                                                                                                          Storyboard.TargetProperty="ScaleX"
                                                                                                          To="1.2" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                                         <DoubleAnimation Storyboard.TargetName="IconScale" 
                                                                                                          Storyboard.TargetProperty="ScaleY"
                                                                                                          To="1.2" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                                                                     </Storyboard>
                                                                                 </BeginStoryboard>
                                                                             </DataTrigger.EnterActions>
                                                                             <DataTrigger.ExitActions>
                                                                                 <StopStoryboard BeginStoryboardName="PulseAnimation"/>
                                                                             </DataTrigger.ExitActions>
                                                                         </DataTrigger>
                                                                     </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Segmented Volume Meter (Discord Style) -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <ProgressBar Value="{Binding DevicesViewModel.MicTestLevel}" 
                                                             Maximum="100" Height="14" Background="Transparent" BorderThickness="0">
                                                    <ProgressBar.Template>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Grid x:Name="TemplateRoot">
                                                                <!-- Inactive background segments -->
                                                                <Rectangle Fill="#2E2E34">
                                                                    <Rectangle.OpacityMask>
                                                                        <VisualBrush TileMode="Tile" Viewport="0,0,8,1" ViewportUnits="Absolute">
                                                                            <VisualBrush.Visual>
                                                                                <Rectangle Fill="White" Width="5" Height="14" RadiusX="1.5" RadiusY="1.5" Margin="0,0,3,0"/>
                                                                            </VisualBrush.Visual>
                                                                        </VisualBrush>
                                                                    </Rectangle.OpacityMask>
                                                                </Rectangle>
                                                                
                                                                <!-- Active colored segments (Bright Green #23A559) -->
                                                                <Grid HorizontalAlignment="Left" Width="{Binding ElementName=PART_Indicator, Path=ActualWidth}" ClipToBounds="True">
                                                                    <Rectangle Width="{Binding ElementName=TemplateRoot, Path=ActualWidth}" HorizontalAlignment="Left" Fill="#23A559">
                                                                        <Rectangle.OpacityMask>
                                                                            <VisualBrush TileMode="Tile" Viewport="0,0,8,1" ViewportUnits="Absolute">
                                                                                <VisualBrush.Visual>
                                                                                    <Rectangle Fill="White" Width="5" Height="14" RadiusX="1.5" RadiusY="1.5" Margin="0,0,3,0"/>
                                                                                </VisualBrush.Visual>
                                                                            </VisualBrush>
                                                                        </Rectangle.OpacityMask>
                                                                    </Rectangle>
                                                                </Grid>
                                                                
                                                                <!-- Hidden tracks for measurement -->
                                                                <Border x:Name="PART_Track" Visibility="Hidden"/>
                                                                <Border x:Name="PART_Indicator" Visibility="Hidden" HorizontalAlignment="Left"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </ProgressBar.Template>
                                                </ProgressBar>
                                            </Grid>
                                        </Grid>

                                        <DockPanel LastChildFill="False" Margin="0,14,0,0">
                                            <TextBlock Text="Test your microphone level and latency." Foreground="{StaticResource TextLow}" FontSize="11" VerticalAlignment="Center"/>
                                            <CheckBox IsChecked="{Binding DevicesViewModel.IsMicLoopback}" 
                                                      DockPanel.Dock="Right" Cursor="Hand">
                                                <CheckBox.Template>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border x:Name="Chk" Width="14" Height="14" CornerRadius="3" 
                                                                    BorderBrush="{StaticResource Border}" BorderThickness="1" 
                                                                    Background="#1AFFFFFF" Margin="0,0,8,0">
                                                                <TextBlock x:Name="CheckMark" Text="✓" FontSize="9" 
                                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                            </Border>
                                                            <TextBlock Text="Listen to this device" Foreground="{StaticResource TextMid}" FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Chk" Property="Background" Value="{StaticResource Accent}"/>
                                                                <Setter TargetName="Chk" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Chk" Property="BorderBrush" Value="{StaticResource TextMid}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </CheckBox.Template>
                                            </CheckBox>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                                <ListBox DockPanel.Dock="Top" Margin="6,6,6,6"
                                         ItemsSource="{Binding DevicesViewModel.InputDevices}"
                                         SelectedItem="{Binding DevicesViewModel.CurrentInputDevice}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Mic icon dot -->
                                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                        Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource TextLow}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" Foreground="{StaticResource TextHi}"
                                                               FontSize="13" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Path Data="M10.949933333333334 11.892666666666665c-0.688 0.3892 -1.4605333333333332 0.6464666666666666 -2.2831333333333332 0.7374V15.333333333333332h-1.3333333333333333v-2.7032666666666665C4.55236 12.322599999999998 2.3441533333333333 10.1144 2.0367266666666666 7.333333333333333h1.3439733333333335c0.32348 2.2615333333333334 2.26842 4 4.619433333333333 4 0.7000666666666666 0 1.3641333333333332 -0.15413333333333332 1.9601333333333333 -0.43039999999999995l-1.0334666666666665 -1.0334666666666665c-0.2942 0.08499999999999999 -0.6051333333333333 0.13053333333333333 -0.9266666666666665 0.13053333333333333 -1.84098 0 -3.33336 -1.4924 -3.33336 -3.333333333333333V5.609473333333334l-3.7377399999999996 -3.7377333333333334L1.8718466666666667 0.9289333333333333l13.199353333333331 13.199333333333332 -0.9428666666666665 0.9427999999999999 -3.1784 -3.1784Zm1.9665333333333335 -1.7857333333333332 -0.9615999999999999 -0.9616666666666666c0.3389333333333333 -0.5396666666666666 0.5704666666666667 -1.1536666666666666 0.6646666666666666 -1.8119333333333334h1.3439333333333332c-0.1132 1.0244 -0.48433333333333334 1.971 -1.047 2.7736Zm-1.9392666666666667 -1.9393333333333331L5.123833333333333 2.31426C5.702846666666667 1.3284533333333333 6.7742 0.6666666666666666 8.000133333333332 0.6666666666666666c1.8409333333333333 0 3.333333333333333 1.4923866666666665 3.333333333333333 3.333333333333333v2.6666666666666665c0 0.5399333333333333 -0.1284 1.0498666666666665 -0.3562666666666666 1.5009333333333332Z" 
                                                          Fill="{StaticResource Red}" Height="16" Width="16" Stretch="Uniform" Margin="8,0,0,0">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </StackPanel>
                                                <Button Grid.Column="2" ToolTip="Set as default call device"
                                                        Command="{Binding DataContext.DevicesViewModel.SetCallInputCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="8,0,0,0" Width="26" Height="26" Cursor="Hand"
                                                        BorderThickness="0" Background="Transparent">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <TextBlock x:Name="Ico" Text="📞" FontSize="13"
                                                                                   Foreground="{StaticResource TextLow}"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCallDevice}" Value="True">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <TextBlock x:Name="Ico" Text="📞" FontSize="13"
                                                                                           Foreground="{StaticResource Accent}"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource AccentDim}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <!-- Output -->
                        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Padding="14,12,14,12"
                                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextMid}"
                                                       FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Speakers &amp; Headphones" Foreground="{StaticResource TextHi}"
                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Command="{Binding DevicesViewModel.TestOutputCommand}"
                                                CommandParameter="{Binding DevicesViewModel.CurrentOutputDevice}"
                                                ToolTip="Test Selected Speaker"
                                                Width="28" Height="28" Cursor="Hand"
                                                BorderThickness="0" Background="Transparent">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" Background="Transparent" CornerRadius="14">
                                                        <Path x:Name="Icon" Data="M8,5.14V19.14L19,12.14L8,5.14Z" 
                                                              Fill="{StaticResource TextMid}" 
                                                              Width="12" Height="12" Stretch="Uniform"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Icon" Property="Fill" Value="{StaticResource Accent}"/>
                                                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgCard}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Icon" Property="Fill" Value="{StaticResource AccentDim}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                                <ListBox DockPanel.Dock="Top" Margin="6,6,6,6"
                                         ItemsSource="{Binding DevicesViewModel.OutputDevices}"
                                         SelectedItem="{Binding DevicesViewModel.CurrentOutputDevice}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                        Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource TextLow}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding FullName}"
                                                           Foreground="{StaticResource TextHi}"
                                                           FontSize="13" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="2" ToolTip="Set as default call device"
                                                        Command="{Binding DataContext.DevicesViewModel.SetCallOutputCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="8,0,0,0" Width="26" Height="26" Cursor="Hand"
                                                        BorderThickness="0" Background="Transparent">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <TextBlock x:Name="Ico" Text="📞" FontSize="13"
                                                                                   Foreground="{StaticResource TextLow}"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCallDevice}" Value="True">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <TextBlock x:Name="Ico" Text="📞" FontSize="13"
                                                                                           Foreground="{StaticResource Accent}"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource AccentDim}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- Volume sliders -->
                    <Border Grid.Row="4" Style="{StaticResource Card}" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Background="Transparent" PreviewMouseWheel="VolumeSlider_PreviewMouseWheel">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Foreground="{StaticResource TextMid}" FontSize="12" VerticalAlignment="Center">
                                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE720;"/>
                                        <Run Text="  Input Volume"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource Accent}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <Binding Path="DevicesViewModel.InputVolume" StringFormat="{}{0:0}%"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Style="{StaticResource VolumeSlider}" Value="{Binding DevicesViewModel.InputVolume}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Background="Transparent" PreviewMouseWheel="VolumeSlider_PreviewMouseWheel">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Foreground="{StaticResource TextMid}" FontSize="12" VerticalAlignment="Center">
                                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE767;"/>
                                        <Run Text="  Output Volume"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource Accent}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <Binding Path="DevicesViewModel.OutputVolume" StringFormat="{}{0:0}%"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Style="{StaticResource VolumeSlider}" Value="{Binding DevicesViewModel.OutputVolume}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Profiles">
                <Grid Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- SEARCH & ACTIONS HEADER -->
                    <Grid Grid.Row="0" Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search Bar -->
                        <Border Grid.Column="0" Background="#0AFFFFFF" CornerRadius="12" Height="44" 
                                HorizontalAlignment="Stretch" MaxWidth="1200" Padding="16,0" Margin="0,0,24,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextLow}" 
                                           FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0" Opacity="0.5"/>
                                <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextHi}"
                                         VerticalContentAlignment="Center" CaretBrush="{StaticResource Accent}"
                                         FontSize="15" Text="{Binding ProfilesViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="HintBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Search profiles..." Foreground="{StaticResource TextLow}" Opacity="0.5"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="{x:Null}">
                                                        <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>

                            <Button Grid.Column="1" Padding="20,0" Height="40"
                                    Style="{StaticResource BtnPrimary}" Command="{Binding ProfilesViewModel.NewCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="New Profile" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                        </Button>
                    </Grid>

                    <!-- LIST CONTENT -->
                    <Grid Grid.Row="1">
                            <!-- EMPTY STATE -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,80"
                                        Visibility="{Binding ProfilesViewModel.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Background="#08FFFFFF" Width="64" Height="64" CornerRadius="32" Margin="0,0,0,16">
                                    <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextLow}" 
                                               FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="No profiles found" Foreground="{StaticResource TextHi}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Create a new profile or clear your search" Foreground="{StaticResource TextLow}" FontSize="13" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>

                        <Grid Visibility="{Binding ProfilesViewModel.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <!-- ItemsControl removes the default blue selection entirely -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,12,12">
                                <ItemsControl ItemsSource="{Binding ProfilesViewModel.FilteredProfiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="ProfileCard" CornerRadius="12" Margin="0,0,0,10" BorderThickness="1" 
                                                    Padding="20,16" Cursor="Hand" HorizontalAlignment="Stretch">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0AFFFFFF"/>
                                                        <Setter Property="BorderBrush" Value="#0FFFFFFF"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#10FFFFFF"/>
                                                                <Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#150078FF"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                
                                                <Grid>
                                                    <!-- Full area clickable -->
                                                    <Grid.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick" 
                                                                    Command="{Binding DataContext.ProfilesViewModel.ActivateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                    </Grid.InputBindings>

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextHi}" FontSize="15" FontWeight="SemiBold"/>
                                                        
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <!-- SELECTED Label -->
                                                            <Border Background="{StaticResource Accent}" CornerRadius="2" Padding="6,2" Margin="0,0,8,0"
                                                                    Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="ACTIVE" Foreground="White" FontSize="9" FontWeight="Black" VerticalAlignment="Center"/>
                                                            </Border>
                                                            
                                                            <!-- Subtitle details -->
                                                            <TextBlock Text="Custom Audio Profile" Foreground="{StaticResource TextLow}" FontSize="11" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Style="{StaticResource BtnGhost}" Width="38" Height="38" Padding="0" Margin="0,0,8,0"
                                                                Command="{Binding DataContext.ProfilesViewModel.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" ToolTip="Edit Profile">
                                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource TextMid}"/>
                                                        </Button>
                                                        <Button Style="{StaticResource BtnGhost}" Width="38" Height="38" Padding="0" 
                                                                Command="{Binding DataContext.ProfilesViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" ToolTip="Delete Profile">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#EE5D5D"/>
                                                        </Button>
                                                    </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                            </Grid>
                    <!-- MODAL OVERLAY: CONFIGURATION EDITOR -->
                    <Grid Visibility="{Binding ProfilesViewModel.IsEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Margin="-24"> <!-- Negative margin to cover the whole tab area -->
                        <Border Background="#CC0F0F11"/> <!-- Dimmed Background -->
                        
                        <Border VerticalAlignment="Center" HorizontalAlignment="Center" Width="520"
                                Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}"
                                BorderThickness="1" CornerRadius="16" Padding="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="40" ShadowDepth="0" Color="Black" Opacity="0.6"/>
                            </Border.Effect>
                            
                            <DockPanel>
                                <!-- Modal Header -->
                                <Border DockPanel.Dock="Top" Background="#0CFFFFFF" Padding="24,16" CornerRadius="16,16,0,0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Edit Profile" Visibility="{Binding ProfilesViewModel.IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Foreground="{StaticResource TextHi}" FontSize="18" FontWeight="Bold"/>
                                            <TextBlock Text="New Profile" Visibility="{Binding ProfilesViewModel.IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                     Foreground="{StaticResource TextHi}" FontSize="18" FontWeight="Bold"/>
                                            <TextBlock Text="Configure your audio preset" Foreground="{StaticResource TextLow}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Style="{StaticResource BtnGhost}" Width="32" Height="32" Padding="0"
                                                Command="{Binding ProfilesViewModel.CancelEditCommand}">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Border Padding="32,24">
                                    <StackPanel>
                                    <TextBlock Text="PROFILE NAME" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding ProfilesViewModel.ProfileName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="40" VerticalContentAlignment="Center" Margin="0,0,0,24"
                                             Padding="12,0" Background="#10FFFFFF" BorderBrush="{StaticResource Border}"
                                             BorderThickness="1" Foreground="{StaticResource TextHi}"/>


                                <!-- Device Grid (2x1 vertical boxes for modal) -->
                                <UniformGrid Columns="2" Rows="2">
                                    <!-- PRIMARY INPUT -->
                                    <StackPanel Margin="0,0,10,20">
                                        <TextBlock Text="PRIMARY INPUT" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding ProfilesViewModel.InputDevices}" SelectedItem="{Binding ProfilesViewModel.SelectedInputDevice}">
                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- PRIMARY OUTPUT -->
                                    <StackPanel Margin="10,0,0,20">
                                        <TextBlock Text="PRIMARY OUTPUT" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding ProfilesViewModel.OutputDevices}" SelectedItem="{Binding ProfilesViewModel.SelectedOutputDevice}">
                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- COMM INPUT -->
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="COMMUNICATION INPUT" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding ProfilesViewModel.InputDevices}" SelectedItem="{Binding ProfilesViewModel.SelectedCallInputDevice}">
                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- COMM OUTPUT -->
                                    <StackPanel Margin="10,0,0,0">
                                        <TextBlock Text="COMMUNICATION OUTPUT" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding ProfilesViewModel.OutputDevices}" SelectedItem="{Binding ProfilesViewModel.SelectedCallOutputDevice}">
                                            <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </UniformGrid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                                    <Button Content="Cancel" Style="{StaticResource BtnGhost}" Width="100" Height="36" Margin="0,0,12,0"
                                            Command="{Binding ProfilesViewModel.CancelEditCommand}"/>
                                    <Button Content="{Binding ProfilesViewModel.SaveButtonText}" Style="{StaticResource BtnPrimary}"
                                            Width="120" Height="36" Command="{Binding ProfilesViewModel.SaveCommand}"/>
                                </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>


            <!-- ──────────────────────── SHORTCUTS TAB -->
            <TabItem Header="Shortcuts">
                <StackPanel Margin="28,24,28,24">
                    <TextBlock Text="Shortcuts" Foreground="{StaticResource TextHi}"
                               FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Global hotkeys — work even when EchoX is in the tray"
                               Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,20"/>

                    <Border Style="{StaticResource Card}" Padding="0">
                        <StackPanel>
                            <Border Padding="18,16" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource AccentLow}"
                                            CornerRadius="8" Width="36" Height="36" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource Accent}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Cycle Profiles" Foreground="{StaticResource TextHi}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Switch to the next saved audio profile"
                                                   Foreground="{StaticResource TextMid}" FontSize="12"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{StaticResource BgRaised}"
                                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            CornerRadius="7" Padding="12,6">
                                        <TextBlock Text="Ctrl + Alt + S" Foreground="{StaticResource TextHi}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="18,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#3B1A1A"
                                            CornerRadius="8" Width="36" Height="36" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource Red}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Toggle Mic Mute" Foreground="{StaticResource TextHi}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Mute or unmute the default microphone"
                                                   Foreground="{StaticResource TextMid}" FontSize="12"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{StaticResource BgRaised}"
                                            BorderBrush="{StaticResource Border}" BorderThickness="1"
                                            CornerRadius="7" Padding="12,6">
                                        <TextBlock Text="Ctrl + Alt + K" Foreground="{StaticResource TextHi}"
                                                   FontFamily="Consolas" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ──────────────────────── SETTINGS TAB -->
            <TabItem Header="Settings">
                <StackPanel Margin="28,24,28,24">
                    <TextBlock Text="Settings" Foreground="{StaticResource TextHi}"
                               FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Configure EchoX behaviour"
                               Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,20"/>
                    <Border Style="{StaticResource Card}" Padding="18,16">
                        <StackPanel>
                            <TextBlock Text="STARTUP" Style="{StaticResource Label}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Launch with Windows" Foreground="{StaticResource TextHi}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="EchoX starts minimised to the system tray"
                                               Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ──────────────────────── ABOUT TAB -->
            <TabItem Header="About">
                <StackPanel Margin="28,24,28,24">
                    <TextBlock Text="About" Foreground="{StaticResource TextHi}"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <Border Style="{StaticResource Card}" Padding="20,18">
                        <StackPanel>
                            <Border Background="{StaticResource AccentLow}" CornerRadius="12"
                                    Width="52" Height="52" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource Accent}" FontSize="26"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="EchoX" Foreground="{StaticResource TextHi}"
                                       FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="Version 1.0.0" Foreground="{StaticResource Accent}"
                                       FontSize="12" Margin="0,4,0,14"/>
                            <TextBlock Foreground="{StaticResource TextMid}" FontSize="13"
                                       TextWrapping="Wrap" LineHeight="22"
                                       Text="A lightweight audio device manager for Windows. Switch between microphones and speakers instantly using profiles and global hotkeys — all from the system tray."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

        </TabControl>
            </Grid>

            <!-- Window controls — float top-right over everything -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                        Orientation="Horizontal" Margin="0,8,10,0" Panel.ZIndex="99">
                <Button Click="MinimizeBtn_Click" Width="38" Height="32"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="─" Foreground="{StaticResource TextMid}"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Background" Value="{StaticResource BgRaised}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Click="MaximizeBtn_Click" Width="38" Height="32"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="□" Foreground="{StaticResource TextMid}"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Background" Value="{StaticResource BgRaised}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Click="CloseBtn_Click" Width="38" Height="32"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="Transparent" CornerRadius="6">
                                <TextBlock x:Name="Lbl" Text="✕" Foreground="{StaticResource TextMid}"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R"   Property="Background" Value="#3F1515"/>
                                    <Setter TargetName="Lbl" Property="Foreground" Value="#F87171"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>
