                                                                        <TextBlock x:Name="Ico" Text="📞" FontSize="13"
                                                                                   Foreground="{StaticResource TextLow}"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCallDevice}" Value="True">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <TextBlock x:Name="Ico" Text="📞" FontSize="13"
                                                                                           Foreground="{StaticResource Accent}"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource AccentDim}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- Volume sliders -->
                    <Border Grid.Row="4" Style="{StaticResource Card}" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Background="Transparent" PreviewMouseWheel="VolumeSlider_PreviewMouseWheel">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Foreground="{StaticResource TextMid}" FontSize="12" VerticalAlignment="Center">
                                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE720;"/>
                                        <Run Text="  Input Volume"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource Accent}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <Binding Path="DevicesViewModel.InputVolume" StringFormat="{}{0:0}%"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Style="{StaticResource VolumeSlider}" Value="{Binding DevicesViewModel.InputVolume}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Background="Transparent" PreviewMouseWheel="VolumeSlider_PreviewMouseWheel">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Foreground="{StaticResource TextMid}" FontSize="12" VerticalAlignment="Center">
                                        <Run FontFamily="Segoe MDL2 Assets" Text="&#xE767;"/>
                                        <Run Text="  Output Volume"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource Accent}"
                                               FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <Binding Path="DevicesViewModel.OutputVolume" StringFormat="{}{0:0}%"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                                <Slider Style="{StaticResource VolumeSlider}" Value="{Binding DevicesViewModel.OutputVolume}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ──────────────────────── PROFILES TAB -->
            <TabItem Header="Profiles">
                <Grid Margin="28,24,28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <StackPanel Grid.Row="0">
                        <!-- Title row -->
                        <Grid Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Profiles" Foreground="{StaticResource TextHi}" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="Save and switch between audio device presets" Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Search + New Profile button row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search bar -->
                            <Border Grid.Column="0" Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    CornerRadius="20" Height="40">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgCard}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding ElementName=ProfilesSearchBox, Path=IsKeyboardFocusWithin}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Margin="10,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Canvas Width="50" Height="50">
                                            <Path Fill="{StaticResource TextLow}"
                                                  Data="M 21 3 C 11.6 3 4 10.6 4 20 C 4 29.4 11.6 37 21 37 C 24.354553 37 27.47104 36.01984 30.103516 34.347656 L 42.378906 46.621094 L 46.621094 42.378906 L 34.523438 30.279297 C 36.695733 27.423994 38 23.870646 38 20 C 38 10.6 30.4 3 21 3 z M 21 7 C 28.2 7 34 12.8 34 20 C 34 27.2 28.2 33 21 33 C 13.8 33 8 27.2 8 20 C 8 12.8 13.8 7 21 7 z"/>
                                        </Canvas>
                                    </Viewbox>

                                    <Grid Grid.Column="1">
                                        <TextBox x:Name="ProfilesSearchBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource TextHi}" VerticalContentAlignment="Center"
                                                 CaretBrush="{StaticResource Accent}" FontSize="13"
                                                 FontWeight="Medium" Padding="0" Margin="0"
                                                 VerticalAlignment="Center"
                                                 Text="{Binding ProfilesViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Text="Search profiles by name"
                                                   Foreground="{StaticResource TextLow}" Opacity="0.72"
                                                   FontSize="13" FontWeight="Medium" IsHitTestVisible="False"
                                                   VerticalAlignment="Center" Margin="0,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=ProfilesSearchBox, Path=Text}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ElementName=ProfilesSearchBox, Path=Text}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- New Profile button -->
                            <Button Grid.Column="2" Style="{StaticResource BtnPrimary}" Height="36" Padding="16,0"
                                    Command="{Binding ProfilesViewModel.NewCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="New Profile" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- MAIN CONTENT: list (left 50%) + detail/editor (right 50%) -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── LEFT: Profile List ── -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Empty state -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding ProfilesViewModel.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Background="{StaticResource BgCard}" Width="56" Height="56" CornerRadius="28" Margin="0,0,0,14">
                                    <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextLow}"
                                               FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="No profiles yet" Foreground="{StaticResource TextHi}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hit New Profile to create one" Foreground="{StaticResource TextLow}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Profile list — same style as device list -->
                            <ListBox ItemsSource="{Binding ProfilesViewModel.FilteredProfiles}"
                                     SelectedItem="{Binding ProfilesViewModel.ActiveProfile}"
                                     Margin="0,0,0,0"
                                     Visibility="{Binding ProfilesViewModel.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding"    Value="0"/>
                                        <Setter Property="Margin"     Value="0,2"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="R" Background="{TemplateBinding Background}" CornerRadius="8"
                                                            BorderBrush="Transparent" BorderThickness="1">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="R" Property="Background" Value="#26262B"/>
                                                            <Setter TargetName="R" Property="BorderBrush" Value="Transparent"/>
                                                            <Setter TargetName="R" Property="BorderThickness" Value="1"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="R" Property="Background" Value="Transparent"/>
                                                            <Setter TargetName="R" Property="BorderBrush" Value="Transparent"/>
                                                            <Setter TargetName="R" Property="BorderThickness" Value="1"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6,8" MinHeight="28">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Dot -->
                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                    Margin="0,0,10,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource TextLow}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <!-- Name -->
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       Foreground="{StaticResource TextHi}" FontSize="13"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                            <!-- Delete — only visible when selected -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Width="28" Height="28" Padding="0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding DataContext.ProfilesViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}" ToolTip="Delete">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Opacity" Value="0"/>
                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent">
                                                                <Viewbox Width="13" Height="13" Stretch="Uniform">
                                                                    <Path Data="M5.755,20.283,4,8H20L18.245,20.283A2,2,0,0,1,16.265,22H7.735A2,2,0,0,1,5.755,20.283ZM21,4H16V3a1,1,0,0,0-1-1H9A1,1,0,0,0,8,3V4H3A1,1,0,0,0,3,6H21a1,1,0,0,0,0-2Z"
                                                                          Fill="{StaticResource Red}" Width="24" Height="24" Stretch="Uniform"/>
                                                                </Viewbox>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- ── RIGHT: Detail view OR Editor ── -->
                        <Border Grid.Column="2" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10">
                            <Grid>
                            <!-- ── DEVICE INFO VIEW (default) ── -->
                            <DockPanel Visibility="{Binding ProfilesViewModel.IsEditorVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <Border DockPanel.Dock="Top" Padding="16,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <!-- Profile name when one is active -->
                                            <TextBlock Foreground="{StaticResource TextHi}" FontSize="14" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Active Devices"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProfilesViewModel.ActiveProfile}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="Active Devices"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Foreground="{StaticResource TextLow}" FontSize="11" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Currently active audio devices"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProfilesViewModel.ActiveProfile}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="Currently active audio devices"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Edit + Delete buttons — only when a profile is selected -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfilesViewModel.ActiveProfile}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Width="30" Height="30" Padding="0" Margin="0,0,4,0"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding ProfilesViewModel.EditCommand}"
                                                    CommandParameter="{Binding ProfilesViewModel.ActiveProfile}"
                                                    ToolTip="Edit profile">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                            <Viewbox Width="13" Height="13" Stretch="Uniform">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Data="M20,16v4a2,2,0,0,1-2,2H4a2,2,0,0,1-2-2V6A2,2,0,0,1,4,4H8"
                                                                          Fill="Transparent" Stroke="{StaticResource TextMid}" StrokeThickness="2"
                                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                                                    <Polygon Points="12.5,15.8 22,6.2 17.8,2 8.3,11.5 8,16"
                                                                             Fill="Transparent" Stroke="{StaticResource TextMid}" StrokeThickness="2"
                                                                             StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BgRaised}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <!-- Active shortcut — docked to bottom -->
                                <Border DockPanel.Dock="Bottom" Padding="16,10"
                                        BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SHORTCUT" Style="{StaticResource Label}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource BgRaised}" BorderBrush="{StaticResource Border}"
                                                BorderThickness="1" CornerRadius="5" Padding="8,3">
                                            <TextBlock Text="{Binding ProfilesViewModel.ActiveShortcutDisplay}"
                                                       FontFamily="Consolas" FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProfilesViewModel.ActiveShortcutDisplay}" Value="None">
                                                                <Setter Property="Foreground" Value="{StaticResource TextLow}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <StackPanel DockPanel.Dock="Top">

                                    <!-- Microphone row -->
                                    <Border Padding="16,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Grid.Column="0" Width="16" Height="16" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <Path Data="M8,1A3,3,0,0,0,5,4v5a3,3,0,0,0,6,0V4A3,3,0,0,0,8,1ZM3.5,8A.5.5,0,0,0,3,8.5a5,5,0,0,0,4.5,4.975V15H6.5a.5.5,0,0,0,0,1h3a.5.5,0,0,0,0-1H8.5V13.475A5,5,0,0,0,13,8.5.5.5,0,0,0,12,8.5a4,4,0,0,1-8,0A.5.5,0,0,0,3.5,8Z"
                                                      Fill="{StaticResource TextMid}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="MICROPHONE" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding DevicesViewModel.CurrentInputDevice.FullName}"
                                                           Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Speaker row -->
                                    <Border Padding="16,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Grid.Column="0" Width="16" Height="16" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <Path Data="M3,9v6h4l5,5V4L7,9H3zm13.5,3A4.5,4.5,0,0,0,14,7.97v8.05A4.5,4.5,0,0,0,16.5,12Z"
                                                      Fill="{StaticResource TextMid}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="SPEAKER" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding DevicesViewModel.CurrentOutputDevice.FullName}"
                                                           Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Comm Mic row -->
                                    <Border Padding="16,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Grid.Column="0" Width="16" Height="16" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <Path Data="M8,1A3,3,0,0,0,5,4v5a3,3,0,0,0,6,0V4A3,3,0,0,0,8,1ZM3.5,8A.5.5,0,0,0,3,8.5a5,5,0,0,0,4.5,4.975V15H6.5a.5.5,0,0,0,0,1h3a.5.5,0,0,0,0-1H8.5V13.475A5,5,0,0,0,13,8.5.5.5,0,0,0,12,8.5a4,4,0,0,1-8,0A.5.5,0,0,0,3.5,8Z"
                                                      Fill="{StaticResource TextMid}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="COMMUNICATION MICROPHONE" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding DevicesViewModel.CurrentCallInputDevice.FullName}"
                                                           Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Comm Speaker row -->
                                    <Border Padding="16,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Grid.Column="0" Width="16" Height="16" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <Path Data="M3,9v6h4l5,5V4L7,9H3zm13.5,3A4.5,4.5,0,0,0,14,7.97v8.05A4.5,4.5,0,0,0,16.5,12Z"
                                                      Fill="{StaticResource TextMid}" Stretch="Uniform"/>
                                            </Viewbox>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="COMMUNICATION SPEAKER" Style="{StaticResource Label}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding DevicesViewModel.CurrentCallOutputDevice.FullName}"
                                                           Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </DockPanel>

                            <!-- ── EDITOR VIEW (New / Edit) ── -->
                            <DockPanel Visibility="{Binding ProfilesViewModel.IsEditorVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- Header -->
                                <Border DockPanel.Dock="Top" Padding="16,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Foreground="{StaticResource TextHi}" FontSize="14" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="New Profile"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfilesViewModel.IsEditing}" Value="True">
                                                            <Setter Property="Text" Value="Edit Profile"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Show profile name when editing -->
                                        <TextBlock Foreground="{StaticResource Accent}" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"
                                                   Text="{Binding ProfilesViewModel.ProfileName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProfilesViewModel.IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Footer buttons -->
                                <Border DockPanel.Dock="Bottom" Padding="16,12" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Cancel" Style="{StaticResource BtnGhost}" Height="38"
                                                Command="{Binding ProfilesViewModel.CancelEditCommand}"/>
                                        <Button Grid.Column="2" Content="{Binding ProfilesViewModel.SaveButtonText}"
                                                Style="{StaticResource BtnPrimary}" Height="38"
                                                Command="{Binding ProfilesViewModel.SaveCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Form fields — flat rows with separators -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- NAME -->
                                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Text="NAME" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding ProfilesViewModel.ProfileName, UpdateSourceTrigger=PropertyChanged}"
                                                         Height="36" VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- PRIMARY INPUT -->
                                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Text="PRIMARY INPUT" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding ProfilesViewModel.InputDevices}"
                                                          SelectedItem="{Binding ProfilesViewModel.SelectedInputDevice}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate><TextBlock Text="{Binding FullName}" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <!-- PRIMARY OUTPUT -->
                                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Text="PRIMARY OUTPUT" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding ProfilesViewModel.OutputDevices}"
                                                          SelectedItem="{Binding ProfilesViewModel.SelectedOutputDevice}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate><TextBlock Text="{Binding FullName}" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <!-- COMMUNICATION INPUT -->
                                        <Border Padding="16,12,16,12" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Text="COMMUNICATION INPUT" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding ProfilesViewModel.InputDevices}"
                                                          SelectedItem="{Binding ProfilesViewModel.SelectedCallInputDevice}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate><TextBlock Text="{Binding FullName}" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <!-- COMMUNICATION OUTPUT -->
                                        <Border Padding="16,12,16,0" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Text="COMMUNICATION OUTPUT" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                                                <ComboBox ItemsSource="{Binding ProfilesViewModel.OutputDevices}"
                                                          SelectedItem="{Binding ProfilesViewModel.SelectedCallOutputDevice}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate><TextBlock Text="{Binding FullName}" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <!-- SHORTCUT KEY (optional) -->
                                        <Border Padding="16,14,16,14" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <TextBlock Text="SHORTCUT KEY" Style="{StaticResource Label}" VerticalAlignment="Center"/>
                                                    <Border Background="{StaticResource BgRaised}" CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="OPTIONAL" Foreground="{StaticResource TextLow}" FontSize="9" FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Key Binds-style row: badge + clear -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Clickable key badge -->
                                                    <Button Grid.Column="0" x:Name="RecordShortcutBtn" Height="36"
                                                            Cursor="Hand" Click="RecordShortcut_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="Bg"
                                                                                    Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    CornerRadius="8">
                                                                                <Grid>
                                                                                    <!-- Idle: shortcut text or placeholder -->
                                                                                    <StackPanel x:Name="IdlePanel" Orientation="Horizontal"
                                                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                                        <TextBlock FontFamily="Consolas" FontSize="13" FontWeight="SemiBold">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Text" Value="{Binding ProfilesViewModel.ShortcutText}"/>
                                                                                                    <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding ProfilesViewModel.ShortcutText}" Value="">
                                                                                                            <Setter Property="Text" Value="Click to assign shortcut"/>
                                                                                                            <Setter Property="Foreground" Value="{StaticResource TextLow}"/>
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding ProfilesViewModel.ShortcutText}" Value="{x:Null}">
                                                                                                            <Setter Property="Text" Value="Click to assign shortcut"/>
                                                                                                            <Setter Property="Foreground" Value="{StaticResource TextLow}"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </StackPanel>
                                                                                    <!-- Recording state -->
                                                                                    <StackPanel x:Name="RecordingPanel" Orientation="Horizontal"
                                                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                Visibility="Collapsed">
                                                                                        <Ellipse Width="7" Height="7" Fill="#F87171" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                                            <Ellipse.Triggers>
                                                                                                <EventTrigger RoutedEvent="Loaded">
                                                                                                    <BeginStoryboard>
                                                                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.6"/>
                                                                                                        </Storyboard>
                                                                                                    </BeginStoryboard>
                                                                                                </EventTrigger>
                                                                                            </Ellipse.Triggers>
                                                                                        </Ellipse>
                                                                                        <TextBlock Text="Press keys…" Foreground="#F87171" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Clear button -->
                                                    <Button Grid.Column="2" Width="36" Height="36" Padding="0"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand" Click="ClearShortcut_Click" ToolTip="Clear shortcut">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="Bg" Background="Transparent"
                                                                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                                                    CornerRadius="8">
                                                                                <TextBlock x:Name="Ico" Text="&#xE711;"
                                                                                           FontFamily="Segoe MDL2 Assets"
                                                                                           Foreground="{StaticResource TextLow}" FontSize="12"
                                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Ico" Property="Foreground" Value="#EF4444"/>
                                                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="#EF4444"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ProfilesViewModel.ShortcutText}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ProfilesViewModel.ShortcutText}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>

                                                <!-- Conflict warning -->
                                                <TextBlock Text="{Binding ProfilesViewModel.ShortcutWarning}"
                                                           Foreground="{StaticResource Amber}" FontSize="11"
                                                           TextWrapping="Wrap" Margin="0,6,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ProfilesViewModel.ShortcutWarning}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ProfilesViewModel.ShortcutWarning}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>


            <!-- ──────────────────────── KEY BINDS TAB -->
            <TabItem Header="Shortcuts">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24,28,24">
                    <TextBlock Text="Key Binds" Foreground="{StaticResource TextHi}"
                               FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Global hotkeys — work even when EchoX is in the tray"
                               Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,20"/>

                    <!-- ── Global Actions ── -->
                    <TextBlock Text="GLOBAL ACTIONS" Foreground="{StaticResource TextLow}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                        <StackPanel>

                            <!-- Open App row -->
                            <Border Padding="18,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE7B5;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextMid}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Open App" Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Show the EchoX window from anywhere" Foreground="{StaticResource TextMid}" FontSize="12"/>
                                    </StackPanel>
                                    <!-- Toggle -->
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"
                                              IsChecked="{Binding KeyBindsViewModel.IsOpenAppEnabled}"
                                              Style="{StaticResource ToggleSwitch}"/>
                                    <!-- Key badge -->
                                    <Button Grid.Column="4" x:Name="OpenAppCaptureBtn" Cursor="Hand" VerticalAlignment="Center"
                                            Click="OpenAppCaptureBtn_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="7" Padding="12,6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KeyBindsViewModel.IsCapturingOpenApp}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentLow}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding KeyBindsViewModel.OpenAppDisplay}"
                                                   Foreground="{StaticResource TextHi}" FontFamily="Consolas" FontSize="12"/>
                                    </Button>
                                    <!-- Reset -->
                                    <Button Grid.Column="6" Width="28" Height="28" Padding="0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding KeyBindsViewModel.ResetOpenAppCommand}" ToolTip="Reset to default">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent" CornerRadius="6">
                                                                <TextBlock x:Name="Ico" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                                                           Foreground="{StaticResource TextLow}" FontSize="12"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Cycle Profiles row -->
                            <Border Padding="18,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextMid}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Cycle Profiles" Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Switch to the next saved audio profile" Foreground="{StaticResource TextMid}" FontSize="12"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"
                                              IsChecked="{Binding KeyBindsViewModel.IsCycleEnabled}"
                                              Style="{StaticResource ToggleSwitch}"/>
                                    <Button Grid.Column="4" x:Name="CycleCaptureBtn" Cursor="Hand" VerticalAlignment="Center"
                                            Click="CycleCaptureBtn_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="7" Padding="12,6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KeyBindsViewModel.IsCapturingCycle}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentLow}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding KeyBindsViewModel.CycleDisplay}"
                                                   Foreground="{StaticResource TextHi}" FontFamily="Consolas" FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="6" Width="28" Height="28" Padding="0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding KeyBindsViewModel.ResetCycleCommand}" ToolTip="Reset to default">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent" CornerRadius="6">
                                                                <TextBlock x:Name="Ico" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                                                           Foreground="{StaticResource TextLow}" FontSize="12"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Toggle Mic Mute row -->
                            <Border Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="0"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextMid}" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Toggle Mic Mute" Foreground="{StaticResource TextHi}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Mute or unmute the default microphone" Foreground="{StaticResource TextMid}" FontSize="12"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center" Margin="0,0,10,0"
                                              IsChecked="{Binding KeyBindsViewModel.IsMuteEnabled}"
                                              Style="{StaticResource ToggleSwitch}"/>
                                    <Button Grid.Column="4" x:Name="MuteCaptureBtn" Cursor="Hand" VerticalAlignment="Center"
                                            Click="MuteCaptureBtn_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="7" Padding="12,6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding KeyBindsViewModel.IsCapturingMute}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentLow}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding KeyBindsViewModel.MuteDisplay}"
                                                   Foreground="{StaticResource TextHi}" FontFamily="Consolas" FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="6" Width="28" Height="28" Padding="0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding KeyBindsViewModel.ResetMuteCommand}" ToolTip="Reset to default">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent" CornerRadius="6">
                                                                <TextBlock x:Name="Ico" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                                                           Foreground="{StaticResource TextLow}" FontSize="12"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Profile Shortcuts ── -->
                    <TextBlock Text="PROFILE SHORTCUTS" Foreground="{StaticResource TextLow}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border Style="{StaticResource Card}" Padding="0">
                        <StackPanel>
                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,20"
                                        Visibility="{Binding ProfilesViewModel.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="No profiles yet" Foreground="{StaticResource TextLow}"
                                           FontSize="13" HorizontalAlignment="Center"/>
                                <TextBlock Text="Create profiles to assign shortcuts to them"
                                           Foreground="{StaticResource TextLow}" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Profile list -->
                            <ItemsControl ItemsSource="{Binding ProfilesViewModel.Profiles}"
                                          Visibility="{Binding ProfilesViewModel.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="18,13"
                                                BorderBrush="{StaticResource Border}"
                                                BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=Content}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Active dot -->
                                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                        Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>

                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Foreground="{StaticResource TextHi}"
                                                           FontSize="13" FontWeight="Medium"
                                                           VerticalAlignment="Center"/>

                                                <!-- Shortcut badge (clickable to capture) -->
                                                <Button Grid.Column="2" Cursor="Hand" VerticalAlignment="Center"
                                                        Tag="{Binding}" Click="KeyBindsEditProfile_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bg"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="7" Padding="12,6">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCapturingShortcut}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentLow}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="{Binding ShortcutDisplay}"
                                                               Foreground="{StaticResource TextHi}"
                                                               FontFamily="Consolas" FontSize="12">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShortcutDisplay}" Value="No shortcut">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextLow}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button>

                                                <!-- Clear button -->
                                                <Button Grid.Column="4" Width="28" Height="28" Padding="0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                        Tag="{Binding}" Click="KeyBindsClearProfile_Click"
                                                        ToolTip="Clear shortcut">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="Transparent" CornerRadius="6">
                                                                            <TextBlock x:Name="Ico" Text="&#xE711;"
                                                                                       FontFamily="Segoe MDL2 Assets"
                                                                                       Foreground="{StaticResource TextLow}"
                                                                                       FontSize="11"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Ico" Property="Foreground" Value="#EF4444"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ──────────────────────── SETTINGS TAB -->
            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24,28,24">
                    <TextBlock Text="Settings" Foreground="{StaticResource TextHi}"
                               FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Configure EchoX behaviour"
                               Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,24"/>

                    <!-- ── GENERAL ── -->
                    <TextBlock Text="GENERAL" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                        <StackPanel>
                            <!-- Launch with Windows -->
                            <Border Padding="18,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="34" Height="34" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextMid}" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Launch with Windows" Foreground="{StaticResource TextHi}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Start minimised to the system tray on login"
                                                   Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                              IsChecked="{Binding SettingsViewModel.LaunchWithWindows}"
                                              Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </Border>
                            <!-- Show mute indicator -->
                            <Border Padding="18,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="34" Height="34" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE74F;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextMid}" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Show Mute Indicator" Foreground="{StaticResource TextHi}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Persistent icon on screen when mic is muted"
                                                   Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                              IsChecked="{Binding SettingsViewModel.ShowMuteIndicator}"
                                              Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── UPDATES ── -->
                    <TextBlock Text="UPDATES" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,20">
                        <StackPanel>
                            <Border Padding="18,14" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="34" Height="34" Margin="0,0,14,0">
                                        <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextMid}" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Notify When Update Available" Foreground="{StaticResource TextHi}"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="Get notified when a new version is released"
                                                   Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                              IsChecked="{Binding SettingsViewModel.UpdateNotifyOnly}"
                                              Style="{StaticResource ToggleSwitch}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── NOTIFICATIONS ── -->
                    <TextBlock Text="NOTIFICATIONS" Style="{StaticResource Label}" Margin="0,0,0,8"/>
                    <TextBlock Text="Choose how EchoX alerts you when switching profiles or muting."
                               Foreground="{StaticResource TextLow}" FontSize="11" Margin="0,0,0,10"/>

                    <!-- 4 fixed-size cards in one row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                        <!-- Popup -->
                        <CheckBox IsChecked="{Binding SettingsViewModel.NotifyPopupScreen}"
                                  Command="{Binding SettingsViewModel.SetNotifyPopupCommand}"
                                  Width="100" Height="90" Margin="0,0,8,0" Cursor="Hand" Focusable="False">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="Card" CornerRadius="10" BorderThickness="1"
                                            Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="Ico" Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextLow}" FontSize="20"
                                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="Lbl" Text="Popup" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMid}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Overlay" FontSize="9" Foreground="{StaticResource TextLow}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>

                        <!-- Sound -->
                        <CheckBox IsChecked="{Binding SettingsViewModel.NotifySoundOnly}"
                                  Command="{Binding SettingsViewModel.SetNotifySoundCommand}"
                                  Width="100" Height="90" Margin="0,0,8,0" Cursor="Hand" Focusable="False">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="Card" CornerRadius="10" BorderThickness="1"
                                            Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="Ico" Text="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextLow}" FontSize="20"
                                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="Lbl" Text="Sound" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMid}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Audio cue" FontSize="9" Foreground="{StaticResource TextLow}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>

                        <!-- Windows -->
                        <CheckBox IsChecked="{Binding SettingsViewModel.NotifyWindows}"
                                  Command="{Binding SettingsViewModel.SetNotifyWindowsCommand}"
                                  Width="100" Height="90" Margin="0,0,8,0" Cursor="Hand" Focusable="False">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="Card" CornerRadius="10" BorderThickness="1"
                                            Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="Ico" Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextLow}" FontSize="20"
                                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="Lbl" Text="Windows" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMid}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="System" FontSize="9" Foreground="{StaticResource TextLow}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>

                        <!-- None -->
                        <CheckBox IsChecked="{Binding SettingsViewModel.NotifyNone}"
                                  Command="{Binding SettingsViewModel.SetNotifyNoneCommand}"
                                  Width="100" Height="90" Cursor="Hand" Focusable="False">
                            <CheckBox.Template>
                                <ControlTemplate TargetType="CheckBox">
                                    <Border x:Name="Card" CornerRadius="10" BorderThickness="1"
                                            Background="{StaticResource BgCard}" BorderBrush="{StaticResource Border}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock x:Name="Ico" Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                       Foreground="{StaticResource TextLow}" FontSize="20"
                                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="Lbl" Text="None" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMid}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Silent" FontSize="9" Foreground="{StaticResource TextLow}"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Ico" Property="Foreground" Value="{StaticResource Accent}"/>
                                            <Setter TargetName="Lbl" Property="Foreground" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </CheckBox.Template>
                        </CheckBox>

                    </StackPanel>

                    <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="34" Height="34" Margin="0,0,14,0">
                                <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="{StaticResource TextMid}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4 8h4V4M20 8h-4V4M4 16h4v4M20 16h-4v4"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Overlay Position"
                                           Foreground="{StaticResource TextHi}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Open a fullscreen editor and drag the notification popup and mute indicator where you want them."
                                           Foreground="{StaticResource TextMid}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,18,0"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Style="{StaticResource BtnPrimary}"
                                    Height="32"
                                    Padding="14,0"
                                    VerticalAlignment="Center"
                                    Click="ArrangeOverlaysBtn_Click"
                                    Content="Arrange Overlays"/>
                        </Grid>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ──────────────────────── ABOUT TAB -->
            <TabItem Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24,28,24">
                    <TextBlock Text="About" Foreground="{StaticResource TextHi}"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <!-- App identity card -->
                    <Border Style="{StaticResource Card}" Padding="24,20" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Logo (no background) -->
                            <Image Grid.Column="0" Source="Assets/LOGO/EchoX.ico"
                                   Width="56" Height="56"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="22" FontWeight="Bold">
                                    <Run Foreground="{StaticResource TextHi}">Echo</Run><Run Foreground="{StaticResource Accent}">X</Run>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding AboutViewModel.AppVersion, StringFormat='v{0}'}"
                                               Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold"/>
                                    <Border Background="{StaticResource BgRaised}" CornerRadius="4"
                                            Padding="7,2" Margin="6,0,0,0">
                                        <TextBlock Text="Windows" Foreground="{StaticResource TextMid}" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Foreground="{StaticResource TextMid}" FontSize="12"
                                           TextWrapping="Wrap" LineHeight="20" Margin="0,10,0,0"
                                           Text="A lightweight audio device manager for Windows. Switch microphones and speakers instantly using profiles and global hotkeys."/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Report a bug -->
                    <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{StaticResource TextMid}" FontSize="15"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Report a Bug" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextHi}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Found an issue? Let us know" FontSize="11"
                                           Foreground="{StaticResource TextMid}" Margin="0,0,0,12"/>
                                <Button Style="{StaticResource BtnGhost}" Height="28" HorizontalAlignment="Left"
                                        Padding="12,0">
                                    <TextBlock FontSize="11">
                                        <Hyperlink NavigateUri="https://github.com/shanto-joseph/EchoX/issues"
                                                   RequestNavigate="Hyperlink_RequestNavigate"
                                                   Foreground="{StaticResource Red}" TextDecorations="{x:Null}">
                                            Open an issue
                                        </Hyperlink>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </Border>

                    <!-- Check for update -->
                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,12">
                        <Border Padding="18,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="34" Height="34" Margin="0,0,14,0"
                                        Background="{StaticResource BgRaised}" CornerRadius="8">
                                    <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{StaticResource TextMid}" FontSize="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Check for Updates" Foreground="{StaticResource TextHi}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="Last checked: " Foreground="{StaticResource TextMid}" FontSize="12"/>
                                        <TextBlock Text="{Binding AboutViewModel.LastChecked}"
                                                   Foreground="{StaticResource TextMid}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2" Style="{StaticResource BtnPrimary}"
                                        Height="30" Padding="14,0" VerticalAlignment="Center"
                                        Command="{Binding AboutViewModel.CheckForUpdateCommand}"
                                        Content="Check now"/>
                            </Grid>
                        </Border>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
            </Grid>

            <!-- Window controls — float top-right over everything -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                        Orientation="Horizontal" Margin="0,8,10,0" Panel.ZIndex="99">
                <Button Click="MinimizeBtn_Click" Width="38" Height="32"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="Transparent" CornerRadius="6">
                                <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" Foreground="{StaticResource TextMid}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Background" Value="{StaticResource BgRaised}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Click="MaximizeBtn_Click" Width="38" Height="32"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="Transparent" CornerRadius="6">
                                <!-- E922 = Maximize, E923 = Restore — swap based on WindowState -->
                                <TextBlock x:Name="Ico"
                                           Text="&#xE922;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMid}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE922;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                    <Setter Property="Text" Value="&#xE923;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R" Property="Background" Value="{StaticResource BgRaised}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Click="CloseBtn_Click" Width="38" Height="32"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="R" Background="Transparent" CornerRadius="6">
                                <TextBlock x:Name="Lbl" Text="✕" Foreground="{StaticResource TextMid}"
                                           FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="R"   Property="Background" Value="#3F1515"/>
                                    <Setter TargetName="Lbl" Property="Foreground" Value="#F87171"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </Grid>
    </Border>
</Window>

