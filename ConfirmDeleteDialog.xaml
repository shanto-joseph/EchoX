<Window x:Class="EchoX.ConfirmDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delete Profile"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="BgBase"    Color="#0F0F11"/>
        <SolidColorBrush x:Key="BgCard"    Color="#1E1E22"/>
        <SolidColorBrush x:Key="BgRaised"  Color="#26262B"/>
        <SolidColorBrush x:Key="Border"    Color="#2E2E34"/>
        <SolidColorBrush x:Key="Accent"    Color="#22C55E"/>
        <SolidColorBrush x:Key="AccentDim" Color="#1B9A4A"/>
        <SolidColorBrush x:Key="TextHi"    Color="#EDEDF0"/>
        <SolidColorBrush x:Key="TextMid"   Color="#9898A0"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerRedDim" Color="#B91C1C"/>
    </Window.Resources>

    <Border Background="{StaticResource BgCard}"
            BorderBrush="{StaticResource Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
        </Border.Effect>

        <StackPanel Margin="28,24,28,24">

            <!-- Icon + Title row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <!-- Trash icon -->
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#22EF4444" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#EF4444"
                                  Data="M7 4a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v1h3a1 1 0 1 1 0 2h-1v13a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7H4a1 1 0 1 1 0-2h3V4zm2 4a1 1 0 0 0-1 1v8a1 1 0 1 0 2 0V9a1 1 0 0 0-1-1zm4 0a1 1 0 0 0-1 1v8a1 1 0 1 0 2 0V9a1 1 0 0 0-1-1z"/>
                        </Canvas>
                    </Viewbox>
                </Border>
                <TextBlock Text="Delete Profile"
                           Foreground="{StaticResource TextHi}"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       Foreground="{StaticResource TextMid}"
                       FontSize="13" TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,24"/>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cancel -->
                <Button Grid.Column="0" x:Name="CancelBtn"
                        Content="Cancel" Height="36"
                        Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMid}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#30303A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Delete -->
                <Button Grid.Column="2" x:Name="DeleteBtn"
                        Content="Delete" Height="36"
                        Cursor="Hand" Click="Delete_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource DangerRedDim}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
